# Copy to .env for local runs. NEVER commit the real .env.
# In GitHub Actions, set SUPABASE_URL and SUPABASE_SERVICE_KEY as repo secrets.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Service-role key (backend only — full access). Settings → API → service_role.
SUPABASE_SERVICE_KEY=

# Anon/public key — used ONLY by the Streamlit dashboard (read side).
SUPABASE_ANON_KEY=

# Password gate for the dashboard.
APP_PASSWORD=

# Local timezone for interpreting bank timestamps without zone info.
LOCAL_TZ=Asia/Bangkok

# Same-amount transactions within this many minutes are treated as one transfer.
DEDUP_WINDOW_MINUTES=10
